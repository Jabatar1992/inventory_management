{
  "info": {
    "_postman_id": "c38f4d1f-f37a-4f21-9c45-6f35f60b4f8b",
    "name": "Inventory Management API",
    "description": "Postman collection for the Inventory Management project PHP API.\n\nBase URL example: http://localhost/inventory_management/api\n\nAuth: Use Authorization header with Bearer token for stock add/reduce endpoints.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "User",
      "item": [
        {
          "name": "Register User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/x-www-form-urlencoded"
              }
            ],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                {"key": "name", "value": "John Doe", "type": "text"},
                {"key": "email", "value": "john@example.com", "type": "text"},
                {"key": "role", "value": "staff", "type": "text"},
                {"key": "password", "value": "Strong@Pass1", "type": "text"}
              ]
            },
            "url": "{{base_url}}/user/reg_user.php",
            "description": "Creates a new user.\n\nRequired: name, email, password\nOptional: role (admin|staff), defaults to staff"
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "let jsonData = {};",
                  "try { jsonData = pm.response.json(); } catch (e) {}",
                  "if (jsonData.status === true && jsonData.data && jsonData.data.access_token) {",
                  "    pm.environment.set('access_token', jsonData.data.access_token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/x-www-form-urlencoded"
              }
            ],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                {"key": "user_id", "value": "1", "type": "text"},
                {"key": "password", "value": "Strong@Pass1", "type": "text"}
              ]
            },
            "url": "{{base_url}}/user/login.php",
            "description": "Login with user_id and password. Stores access token to environment variable access_token when successful."
          }
        }
      ]
    },
    {
      "name": "Product",
      "item": [
        {
          "name": "Add Product",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/x-www-form-urlencoded"
              }
            ],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                {"key": "name", "value": "Wireless Mouse", "type": "text"},
                {"key": "sku", "value": "WM-1001", "type": "text"},
                {"key": "category", "value": "Accessories", "type": "text"},
                {"key": "price", "value": "25.99", "type": "text"},
                {"key": "quantity", "value": "50", "type": "text"}
              ]
            },
            "url": "{{base_url}}/product/add_product.php"
          }
        },
        {
          "name": "List Products",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/product/list_product.php",
            "description": "Returns all products ordered by created_at DESC."
          }
        },
        {
          "name": "Update Product",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/x-www-form-urlencoded"
              }
            ],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                {"key": "product_id", "value": "1", "type": "text"},
                {"key": "name", "value": "Wireless Mouse Pro", "type": "text"},
                {"key": "sku", "value": "WM-1001", "type": "text"},
                {"key": "category", "value": "Accessories", "type": "text"},
                {"key": "price", "value": "29.99", "type": "text"},
                {"key": "quantity", "value": "45", "type": "text"}
              ]
            },
            "url": "{{base_url}}/product/update_product.php"
          }
        },
        {
          "name": "Delete Product",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/x-www-form-urlencoded"
              }
            ],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                {"key": "product_id", "value": "1", "type": "text"}
              ]
            },
            "url": "{{base_url}}/product/delete_product.php"
          }
        }
      ]
    },
    {
      "name": "Stock Management",
      "item": [
        {
          "name": "Add Stock (Auth)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/x-www-form-urlencoded"
              }
            ],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                {"key": "product_id", "value": "1", "type": "text"},
                {"key": "quantity", "value": "10", "type": "text"}
              ]
            },
            "url": "{{base_url}}/stock_management/add_stock.php",
            "description": "Requires Bearer token. User ID is read from token payload."
          }
        },
        {
          "name": "Reduce Stock When Sell (Auth)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/x-www-form-urlencoded"
              }
            ],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                {"key": "product_id", "value": "1", "type": "text"},
                {"key": "quantity", "value": "2", "type": "text"}
              ]
            },
            "url": "{{base_url}}/stock_management/reduce_stock_whensell.php"
          }
        },
        {
          "name": "Stock History",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/stock_management/stock_history.php?product_id=1&user_id=1",
              "host": ["{{base_url}}"],
              "path": ["stock_management", "stock_history.php"],
              "query": [
                {"key": "product_id", "value": "1", "disabled": true},
                {"key": "user_id", "value": "1", "disabled": true}
              ]
            },
            "description": "Query params are optional. Enable only what you need."
          }
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost/inventory_management/api"
    },
    {
      "key": "access_token",
      "value": ""
    }
  ]
}